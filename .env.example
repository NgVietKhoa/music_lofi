# Server (npm start / Vercel) — lấy danh sách ảnh nền tự động từ Cloudinary
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@dwusxbhbr
# Folder asset trên Cloudinary (mặc định img_gif)
# CLOUDINARY_ASSET_FOLDER=img_gif
# Cache danh sách nền trên server (ms, mặc định 600000 = 10 phút)
# BG_LIST_CACHE_MS=600000
